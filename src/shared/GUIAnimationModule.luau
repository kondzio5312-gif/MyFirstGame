local RunService = game:GetService("RunService")

local ActiveGui = {} -- This Will Prevent multiple animations on the same GUI.

local Animations = {
}
-- Converts tables or nils to valid UDim2s
local function toUDim2(value)
	if typeof(value) == "UDim2" then
		return value
	elseif typeof(value) == "table" and #value == 4 then
		return UDim2.new(value[1], value[2], value[3], value[4])
	else
		return UDim2.new()
	end
end

-- Applies properties to GUI safely
local function applyProps(gui, props)
	local pos = toUDim2(props.Position)
	local size = toUDim2(props.Size)
	
	if pos then gui.Position = pos end
	if size then gui.Size = size end
	
	if props.BackgroundTransparency ~= nil then
		gui.BackgroundTransparency = props.BackgroundTransparency
	end
end

-- Catmull-Rom number interpolation
local function catmullRomNum(p0, p1, p2, p3, t)
	p0, p1, p2, p3 = p0 or p1, p1 or 0, p2 or p1, p3 or p2
	return 0.5 * ((2*p1)
		+ (-p0 + p2)*t
		+ (2*p0 - 5*p1 + 4*p2 - p3)*t^2
		+ (-p0 + 3*p1 - 3*p2 + p3)*t^3)
end

-- Catmull-Rom interpolation for UDim2s
local function catmullRom(p0, p1, p2, p3, t)
	p0 = toUDim2(p0 or p1)
	p1 = toUDim2(p1)
	p2 = toUDim2(p2 or p1)
	p3 = toUDim2(p3 or p2 or p1)
	
	return UDim2.new(
		catmullRomNum(p0.X.Scale, p1.X.Scale, p2.X.Scale, p3.X.Scale, t),
		catmullRomNum(p0.X.Offset, p1.X.Offset, p2.X.Offset, p3.X.Offset, t),
		catmullRomNum(p0.Y.Scale, p1.Y.Scale, p2.Y.Scale, p3.Y.Scale, t),
		catmullRomNum(p0.Y.Offset, p1.Y.Offset, p2.Y.Offset, p3.Y.Offset, t)
	)
end

-- Plays animation using Catmull-Rom interpolation
function Animations:Play(gui, name)
	local data = self[name or "Default"]
	if not data then
		warn("No animation found:", name)
		return
	end
	
	-- Cancel any currently running animation on this gui
	if ActiveGui[gui] and ActiveGui[gui].Connection then
		ActiveGui[gui].Connection:Disconnect()
	end
	
	-- Get the current visual state as a new starting point
	local currentProps = {
		Position = gui.Position,
		Size = gui.Size,
		BackgroundTransparency = gui.BackgroundTransparency,
	}
	
	-- Clone and prepend the current state as a starting keyframe
	local frames = table.clone(data.Keyframes)
	table.sort(frames, function(a, b) return a.Time < b.Time end)
	table.insert(frames, 1, {
		Time = 0,
		Properties = currentProps,
	})
	
	local total = data.TotalTime
	local start = tick()
	
	local animData = {}
	ActiveGui[gui] = animData
	
	local conn
	conn = RunService.Heartbeat:Connect(function()
		local t = tick() - start
		if t > total then
			applyProps(gui, frames[#frames].Properties)
			conn:Disconnect()
			ActiveGui[gui] = nil
			return
		end
		
		-- Before first frame
		if t <= frames[1].Time then
			applyProps(gui, frames[1].Properties)
			return
		end
		
		-- After last frame
		if t >= frames[#frames].Time then
			applyProps(gui, frames[#frames].Properties)
			return
		end
		
		-- Find current segment
		local i1 = 1
		for i = 1, #frames - 1 do
			if t >= frames[i].Time and t <= frames[i + 1].Time then
				i1 = i
				break
			end
		end
		
		local function get(i)
			return frames[math.clamp(i, 1, #frames)]
		end
		
		local k0, k1, k2, k3 = get(i1 - 1), get(i1), get(i1 + 1), get(i1 + 2)
		local dt = k2.Time - k1.Time
		local alpha = (dt == 0) and 0 or (t - k1.Time) / dt
		alpha = math.clamp(alpha, 0, 1)
		
		local props = {}
		
		if k1.Properties.Position and k2.Properties.Position then
			props.Position = catmullRom(
				k0.Properties.Position or k1.Properties.Position,
				k1.Properties.Position,
				k2.Properties.Position,
				k3.Properties.Position or k2.Properties.Position,
				alpha
			)
		end
		if k1.Properties.Size and k2.Properties.Size then
			props.Size = catmullRom(
				k0.Properties.Size or k1.Properties.Size,
				k1.Properties.Size,
				k2.Properties.Size,
				k3.Properties.Size or k2.Properties.Size,
				alpha
			)
		end
		if k1.Properties.BackgroundTransparency and k2.Properties.BackgroundTransparency then
			props.BackgroundTransparency = catmullRomNum(
				k0.Properties.BackgroundTransparency or k1.Properties.BackgroundTransparency,
				k1.Properties.BackgroundTransparency,
				k2.Properties.BackgroundTransparency,
				k3.Properties.BackgroundTransparency or k2.Properties.BackgroundTransparency,
				alpha
			)
		end
		
		applyProps(gui, props)
	end)
	
	animData.Connection = conn
end

return Animations
